# Kopiera till engine/.env för lokal körning (committas ALDRIG – se .gitignore).
# I GitHub Actions läggs samma värden in som repo-secrets (Settings → Secrets).

# Din Anthropic-nyckel (motorn använder DIN nyckel, till skillnad från appen
# där användaren klistrar in sin egen i webbläsaren). Du står för kostnaden.
ANTHROPIC_API_KEY=sk-ant-...

# Supabase – projektets URL och SERVICE ROLE-nyckeln (inte anon-nyckeln!).
# Service-nyckeln kringgår RLS och får aldrig hamna i klienten.
SUPABASE_URL=https://rbilywmxxdlnsxbrqees.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Valfritt: byt triage-modell (default claude-haiku-4-5).
# ENGINE_TRIAGE_MODEL=claude-haiku-4-5

# Fas 2 – djupanalys-kaskad (valfritt, default på).
# ENGINE_DEEP_ENABLED=true              # sätt "false" för att stänga av djupsteget
# ENGINE_DEEP_MODEL=claude-opus-4-8     # djupmodell (t.ex. claude-sonnet-4-6 för lägre kostnad)
# ENGINE_DEEP_THRESHOLD=0.5             # impact-tröskel för att gå till djupanalys
# ENGINE_DEEP_MAX=20                    # max antal djupanrop per varv (kostnadstak)
